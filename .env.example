OPENAI_API_KEY=your_openai_key
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

DATABASE_USERNAME=oncall
DATABASE_PASSWORD=oncall

OPERATIONS_SYNC_ENABLED=true
OPERATIONS_SYNC_FIXED_DELAY_MS=60000
OPERATIONS_LOGS_LOOKBACK_MINUTES=15

PROMETHEUS_ENABLED=false
PROMETHEUS_BASE_URL=http://prometheus:9090
PROMETHEUS_ALERTS_PATH=/api/v1/alerts

MCP_LOGS_ENABLED=false
MCP_LOGS_ENDPOINT=http://mcp-logs:8081/mcp/logs/query
MCP_LOGS_QUERY=error OR exception OR timeout OR failed
MCP_LOGS_LIMIT=200
